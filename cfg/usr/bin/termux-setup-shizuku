#!/data/data/com.termux/files/usr/bin/env bash
# SPDX-License-Identifier: 0BSD
# Setup Shizuku (https://github.com/RikkaApps/Shizuku)
set -e

usage() {
  echo "usage: ${0##*/} [-h]"
  echo
  echo 'setup shizuku (https://github.com/rikkaapps/shizuku)'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  echo
  echo "do not forget to export files into ${HOME}/shizuku"
  echo 'after starting shizuku'
  exit "${1}"
}

get_link() {
  curl -f 'https://api.github.com/repos/RikkaApps/Shizuku/releases/latest' \
    | grep "browser_download_url.*apk" | cut -d ':' -f '2,3' | tr -d \" \
    | cut -c '2-'
}

main() {
  [[ "${@}" == '-h' ]] && usage 0

  local apk="${TMPDIR}/shizuku.apk"
  local conf="${HOME}/.termux/termux.properties"
  curl -fL -o "${apk}" "$(get_link)"
  echo 'allow-external-apps = true' > "${conf}"
  echo '- Press ENTER to continue'
  local i
  read -r i && unset i
  termux-open "${apk}"
  echo 'allow-external-apps = false' > "${conf}"
  echo "- After starting shizuku export files into ${HOME}/shizuku"
}

main "${@}"
