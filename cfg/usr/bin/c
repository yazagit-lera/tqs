#!/data/data/com.termux/files/usr/bin/env bash
# SPDX-License-Identifier: 0BSD
# Get command path
set -e

usage() {
  echo "usage: ${0##*/} [-h] COMMAND"
  echo
  echo 'get command path'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  exit "${1}"
}

main() {
  ((${#} == 0)) && usage 1 >&2
  [[ "${@}" == '-h' ]] && usage 0

  command -v "${@}"
}

main "${@}"
