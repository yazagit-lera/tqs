#!/data/data/com.termux/files/usr/bin/env bash
#
# Elevate privileges
set -e

unset LD_LIBRARY_PATH LD_PRELOAD

usage() {
  echo "usage: ${0##*/} [-h] [COMMAND]"
  echo
  echo 'elevate privileges'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'

  exit "${1}"
}

main() {
  local command="${@}"
  local bin='/system/bin/su'

  if [[ ! -x "${bin}" ]]; then
    echo "! ${bin} not found" >&2
    exit 1
  fi

  [[ "${@}" = '-h' ]] && usage 0

  echo '- ROOT'
  [[ -n "${@}" ]] && local opt='-c'
  PATH="${PATH}:/system_ext/bin:/product/bin:/vendor/bin:/system/bin" \
    exec "${bin}" -c "${SHELL}" "${opt}" "${command}"
}

main "${@}"
