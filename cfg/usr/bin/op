#!/data/data/com.termux/files/usr/bin/env bash
# SPDX-License-Identifier: 0BSD
# sshd alias
set -e

usage() {
  echo "usage: ${0##*/} [-h] [-s] [-x] [-e] [-d] [-c]"
  echo
  echo 'sshd alias'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  echo '  -s  start sshd'
  echo '  -x  kill sshd'
  echo '  -e  enable password auth'
  echo '  -d  disable password auth'
  echo '  -c  clear authorized_keys'
  exit "${1}"
}

main() {
  local OPTARG
  local arg

  # Parse args
  ((${#} == 0)) && usage 1 >&2
  while getopts 'hsxedc' arg; do
    case "${arg}" in
      s) local cmd="${arg}" ;;
      x) local cmd="${arg}" ;;
      e) local cmd="${arg}" ;;
      d) local cmd="${arg}" ;;
      c) local cmd="${arg}" ;;
      h) usage 0 ;;
      *) usage 1 >&2 ;;
    esac
  done

  local password_conf="${PREFIX}/etc/ssh/sshd_config.d/password-auth.conf"
  case "${cmd}" in
    s) sshd -p8022 ;;
    x) pidof -q sshd && pkill sshd ;;
    e)
      [[ ! -f "${HOME}/.termux_authinfo" ]] && passwd
      echo 'PasswordAuthentication yes' > "${password_conf}"
      ;;
    d) echo 'PasswordAuthentication no' > "${password_conf}" ;;
    c) echo > "${HOME}/.ssh/authorized_keys" ;;
    *) usage 1 >&2 ;;
  esac
}

main "${@}"
