#!/data/data/com.termux/files/usr/bin/env bash
#
# Openssh helper

set -e
passconf="${PREFIX}/etc/ssh/sshd_config.d/passauth.conf"

if [[ "${@}" =~ '-h' ]]; then
  cat << 'EOF'
- (Re)start `sshd`
  Use option `k` to kill the server
  and `c` to clear authorized keys

  py - Enable password auth (for first connect)
  pn - Disable password auth
- Example:
  op py
  op c
EOF

  exit 0
fi

if [[ "${1}" == 'pn' ]]; then
  echo 'PasswordAuthentication no' > "${passconf}"
elif [[ "${1}" == 'py' ]]; then
  [[ ! -f "${HOME}/.termux_authinfo" ]] && passwd
  echo 'PasswordAuthentication yes' > "${passconf}"
fi

if [[ "${1}" == 'c' ]]; then
  echo > "${HOME}/.ssh/authorized_keys"
  exit 0
fi

pidof -q sshd && pkill sshd
[[ "${1}" != 'k' ]] && sshd -p8022
