#!/system/bin/env sh
#
# Setup pacman in termux
set -e

dir="${PREFIX%/*}/tqs"
path="${PREFIX}/tmp/tqs"
readonly ext='.tar.lz4'
url="https://github.com/nedorazrab0/tqs/releases/download/tqs/\
${path##*/}${ext}"

# Check failsafe
if [[ -n "${TERMUX_MAIN_PACKAGE_FORMAT}" ]]; then
  echo '! Not failsafe'
  echo '- Left edge swipe ==> "new session" (long-tap)'
  exit 1
fi

# Main
[[ -d "${dir}" ]] && rm -rf "${dir}"
mkdir -p "${dir}"

if [[ "$(uname -m)" == 'aarch64' ]]; then
  arch='aarch64'
else
  arch='arm'
fi

curl -fLZ "https://github.com/termux-pacman/termux-packages/\
releases/latest/download/bootstrap-${arch}.zip" \
  -o "${PREFIX}/bstrp.zip"

unzip "${PREFIX}/bstrp.zip" -d "${dir}"
cd "${dir}"  # For symlinks
awk -F '←' \
  '{system("ln -sv '"'"'"$1"'"'"' '"'"'"$2"'"'"' &")}' \
  "${dir}/SYMLINKS.txt"
rm -f "${dir}/SYMLINKS.txt"
rm -rf "${PREFIX}"
cd ..
mv "${dir}" "${PREFIX}"

# EXT
export PATH="${PREFIX}/bin"

echo '[options]
HoldPkg = pacman
Architecture = auto

Color
CheckSpace
VerbosePkgLists
ParallelDownloads = 12

SigLevel = DatabaseRequired
LocalFileSigLevel = Optional

# Repo
[main]
Include = /data/data/com.termux/files/usr/etc/pacman.d/serverlist' \
  > "${PREFIX}/etc/pacman.conf"

# skip ssh algs
mkdir -p "${PREFIX}/etc/ssh"
for alg in rsa ecdsa; do
  ln -svf /dev/null "${PREFIX}/etc/ssh/ssh_host_${alg}_key"
done

pacman-key --init
pacman-key --populate

pacman -Syyu --noconfirm
pacman -S zsh{,-completions} micro lz4 openssh \
  bsdtar git python man file --noconfirm
pacman -Rddn command-not-found --noconfirm  # Poshlo nahui

rm -rf "${PREFIX%/*}/home/"*
curl -fL -o "${path}${ext}" "${url}"

[[ -d "${path}" ]] && rm -rf "${path}"
mkdir -p "${path}"
lz4 -dc "${path}${ext}" | bsdtar -x -C "${path}"
rm -f "${path}${ext}"

exec bash "${path}/ext"
