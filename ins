#!/system/bin/env sh
#
# Setup pacman in termux
set -e

dir="${PREFIX%/*}/tqs"
path="${PREFIX%/*}/tmp/tqs"
readonly ext='.tar.lz4'
url="https://github.com/nedorazrab0/tqs/releases/download/tqs/\
${path##*/}${ext}"

[[ -d "${dir}" ]] && rm -rf "${dir}"
mkdir -p "${dir}"

curl -fLZ "https://github.com/termux-pacman/termux-packages/\
releases/latest/download/bootstrap-aarch64.zip" \
  -o "${PREFIX}/bstrp.zip"

unzip "${PREFIX}/bstrp.zip" -d "${dir}"
cd "${dir}"  # For symlinks
awk -F '←' \
  '{system("ln -sv '"'"'"$1"'"'"' '"'"'"$2"'"'"' &")}' \
  "${dir}/SYMLINKS.txt"
rm -f "${dir}/SYMLINKS.txt"
rm -rf "${PREFIX}"
cd ..
mv "${dir}" "${PREFIX}"

# EXT
export PATH="${PREFIX}/bin"
curl -fL -o "${path}${ext}" "${url}"

[[ -d "${path}" ]] && rm -rf "${path}"
mkdir -p "${path}"
lz4 -dc "${path}${ext}" | bsdtar -x -C "${path}"
rm -f "${path}${ext}"

exec bash "${path}/ext"
