#!/system/bin/env sh
#
# Setup pacman in termux

set -e
dir="${PREFIX%/*}/tqs"

[[ -d "${dir}" ]] rm -rf "${dir}"
mkdir -p "${dir}"

curl -fLZ \
  "https://github.com/termux-pacman/termux-packages/\
releases/latest/download/bootstrap-aarch64.zip" \
  | unzip -d "${dir}"

awk -F '←' \
  '{system("ln -sv '"'"'"$1"'"'"' '"'"'"$2"'"'"' &")}' \
  "${dir}/SYMLINKS.txt"
rm -f "${dir}/SYMLINKS.txt"
rm -rf "${PREFIX}"
mv "${dir}" "${PREFIX}"
