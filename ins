#!/system/bin/env sh
#
# Setup pacman in termux
set -e

cd "${PREFIX%/*}"
mkdir -p ./tqs
cd ./tqs
curl -LZ -o tqs.zip 'https://github.com/termux-pacman/termux-packages/releases/latest/download/bootstrap-aarch64.zip'
unzip tqs.zip && rm -f ./tqs.zip

cat ./SYMLINKS.txt | while read -r sym; do
  ln -sv "${sym//←/ /}" &
done
wait
rm -f ./SYMLINKS.txt
cd ..
rm -rf "${PREFIX}"
mv ./tqs "${PREFIX}"
