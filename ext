#!/data/data/com.termux/files/usr/bin/env bash
#
# EXT
set -e

id="$(id -u)"
bsdtar --uid "${id}" --gid "${id}" \
  -x -f "${PREFIX}/tmp/tqs/cfg.tar" -C "${PREFIX%/*}"

chsh -s zsh
rm -rf "${PREFIX}/etc/termux"
echo > "${PREFIX}/etc/motd"
[[ ! -d "${PREFIX%/*}/home/storage" ]] && termux-setup-storage

curl -f -o "${PREFIX}/tmp/api.apk" \
  'https://f-droid.org/repo/com.termux.api_51.apk'
termux-setup-package-manager
termux-open "${PREFIX}/tmp/api.apk"
read -r ans && unset ans
echo > "${PREFIX%/*}/home/.termux/termux.properties"

echo '- That is all. Close old sessions,
  then start new one'
