#!/data/data/com.termux/files/usr/bin/env bash
#
# Extra
set -e

skip_ssh_algs() {
  mkdir -p -- "${PREFIX}/etc/ssh"
  for alg in rsa ecdsa; do
    ln -svf -- /dev/null "${PREFIX}/etc/ssh/ssh_host_${alg}_key"
  done
}

pkgs() {
  pacman -S zsh micro openssh git python man file --noconfirm
  pacman -Rsn command-not-found --noconfirm  # Idi nahui
}

main() {
  local tmp="${PREFIX}/tmp/tqs"

  skip_ssh_algs  
  pkgs
  
  # Extract files
  local id
  id="$(id -u)"
  bsdtar --uid "${id}" --gid "${id}" -x -f "${tmp}/cfg.tar" -C "${PREFIX}/.."
  
  chsh -s zsh
  rm -rf -- "${PREFIX}/etc/termux"
  mkdir -p "${HOME}/shizuku"
  echo > "${PREFIX}/etc/motd"
  [[ ! -d "${HOME}/storage" ]] && termux-setup-storage
  
  echo
  echo '- Press ENTER to continue'
  read -r entr && unset entr
  kill "${TERMUX_APP_PID}"
}

main
